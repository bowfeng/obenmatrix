package oben:wasm;

/// WIT interface for WASM plugin hooks.
/// Plugins implement the exported interfaces below. The host (Rust) calls
/// these functions from hook emission paths in the agent loop.
///
/// Hook categories:
/// - turn: per-turn lifecycle events
/// - tool: tool execution lifecycle events
/// - streaming: LLM streaming output events
/// - system: status and diagnostic events
/// - session: session lifecycle events
///
/// Agent loop and interrupt hooks are NOT included in Phase 1
/// (they are startup-only or Ctrl+C events, not runtime-useful).

world hook-plugin-world {
    /// Host-side exports — WASM plugin calls these to provide hook metadata
    export plugin-metadata;

    /// Guest-side imports — host calls these when events are emitted
    import turn;
    import tool;
    import streaming;
    import system;
    import session;
}

/// Plugin metadata exports the plugin identifier and priority
interface plugin-metadata {
    /// Unique identifier for this plugin (e.g., "my-hook-plugin")
    plugin-id: func() -> string;

    /// Hook priority (lower = earlier in dispatch order).
    /// Default value is 100.
    plugin-priority: func() -> u32;
}

/// Turn lifecycle events — fires once per execute_turn call
interface turn {
    /// Called before the turn cycle begins (budget check, compression prep)
    on-pre-turn: func();

    /// Called after the turn cycle ends (all tool calls resolved or final response)
    /// @param response the final text output
    /// @param success whether the turn completed without error
    on-post-turn: func(response: string, success: bool);
}

/// Tool execution lifecycle events
interface tool {
    /// Tool call generated by LLM (before execution)
    /// @param tool_name the name of the tool (e.g., "shell")
    /// @param call_id unique identifier for this tool call
    on-tool-gen: func(tool_name: string, call_id: string);

    /// Tool execution begins
    /// @param tool_name the name of the tool
    /// @param args JSON string of tool arguments
    on-tool-start: func(tool_name: string, args: string);

    /// Tool execution completes
    /// @param tool_name the name of the tool
    /// @param args JSON string of tool arguments
    /// @param result the tool's output
    on-tool-complete: func(tool_name: string, args: string, result: string);

    /// Tool execution failed with an error
    /// @param tool_name the name of the tool
    /// @param args JSON string of tool arguments
    /// @param error error message from the tool
    on-tool-error: func(tool_name: string, args: string, error: string);

    /// Tool progress update (optional, for long-running tools)
    /// @param tool_name the name of the tool
    /// @param preview brief preview of progress
    on-tool-progress: func(tool_name: string, preview: string);
}

/// LLM output streaming events
interface streaming {
    /// Main response text delta
    /// @param text the text chunk
    on-stream-delta: func(text: string);

    /// Thinking/reasoning text delta (from models that support it)
    /// @param text the thinking text chunk
    on-thinking: func(text: string);

    /// Reasoning text delta (separate from thinking)
    /// @param text the reasoning text chunk
    on-reasoning: func(text: string);

    /// Interim assistant message (non-streaming, full text)
    /// @param text the interim message text
    on-interim-assistant: func(text: string);
}

/// System status and diagnostic events
interface system {
    /// Status message with level
    /// @param level log level (e.g., "lifecycle", "warn", "info")
    /// @param message status message
    on-status: func(level: string, message: string);
}

/// Session lifecycle events
interface session {
    /// Called when a session is rotated (compressed → parent ended, child created)
    /// @param parent_id the old session ID
    /// @param child_id the new session ID
    on-session-rotate: func(parent_id: string, child_id: string);

    /// Called before context compression begins
    /// @param message_count number of messages before compression
    on-compression-start: func(message_count: u32);

    /// Called after context compression completes
    /// @param status result: "compacted", "unchanged", "ineffective"
    on-compression-complete: func(status: string);
}
