package oben:wasm;

/// WIT interface for WASM plugin hooks.
/// Plugins implement the exported interfaces below. The host (Rust) calls
/// these functions from hook emission paths in the agent loop.
///
/// Hook categories:
/// - turn: per-turn lifecycle events
/// - tool: tool execution lifecycle events
/// - streaming: LLM streaming output events
/// - system: status and diagnostic events
/// - session: session lifecycle events
///
/// Agent loop and interrupt hooks are NOT included in Phase 1
/// (they are startup-only or Ctrl+C events, not runtime-useful).

// ---------------------------------------------------------------------------
// Host exports to guest — WASM plugins call these to register tools, commands,
// and use host services. Plugins can call these at ANY time
/// (not just at init).

world hook-plugin-world {
    // HOST EXPORTS TO GUEST (plugin calls)
    export plugin-registry;
    export cli-command;
    export host-services;
    export inject-message;
    export chat-completion;

    // GUEST EXPORTS TO HOST (host calls during events)
    export plugin-metadata;

    // GUEST IMPORTS (host calls during events)
    import turn;
    import tool;
    import streaming;
    import system;
    import session;
}

// ---------------------------------------------------------------------------
// Package-level interface definitions — placed OUTSIDE the world.

/// Plugin metadata exports the plugin identifier and priority
interface plugin-metadata {
    /// Unique identifier for this plugin (e.g., "my-hook-plugin")
    plugin-id: func() -> string;

    /// Hook priority (lower = earlier in dispatch order).
    /// Default value is 100.
    plugin-priority: func() -> u32;
}

/// Turn lifecycle events — fires once per execute_turn call
interface turn {
    /// Called before the turn cycle begins (budget check, compression prep)
    on-pre-turn: func();

    /// Called after the turn cycle ends (all tool calls resolved or final response)
    /// @param response the final text output
    /// @param success whether the turn completed without error
    on-post-turn: func(response: string, success: bool);
}

/// Tool execution lifecycle events
interface tool {
    /// Tool call generated by LLM (before execution)
    /// @param tool-name the name of the tool (e.g., "shell")
    /// @param call-id unique identifier for this tool call
    on-tool-gen: func(tool-name: string, call-id: string);

    /// Tool execution begins
    /// @param tool-name the name of the tool
    /// @param args JSON string of tool arguments
    on-tool-start: func(tool-name: string, args: string);

    /// Tool execution completes
    /// @param tool-name the name of the tool
    /// @param args JSON string of tool arguments
    /// @param result the tool's output
    on-tool-complete: func(tool-name: string, args: string, output: string);

    /// Tool execution failed with an error
    /// @param tool-name the name of the tool
    /// @param args JSON string of tool arguments
    /// @param error error message from the tool
    on-tool-error: func(tool-name: string, args: string, error: string);

    /// Tool progress update (optional, for long-running tools)
    /// @param tool-name the name of the tool
    /// @param preview brief preview of progress
    on-tool-progress: func(tool-name: string, preview: string);
}

/// LLM output streaming events
interface streaming {
    /// Main response text delta
    /// @param text the text chunk
    on-stream-delta: func(text: string);

    /// Thinking/reasoning text delta (from models that support it)
    /// @param text the thinking text chunk
    on-thinking: func(text: string);

    /// Reasoning text delta (separate from thinking)
    /// @param text the reasoning text chunk
    on-reasoning: func(text: string);

    /// Interim assistant message (non-streaming, full text)
    /// @param text the interim message text
    on-interim-assistant: func(text: string);
}

/// System status and diagnostic events
interface system {
    /// Status message with level
    /// @param level log level (e.g., "lifecycle", "warn", "info")
    /// @param message status message
    on-status: func(level: string, message: string);
}

/// Session lifecycle events
interface session {
    /// Called when a session is rotated (compressed → parent ended, child created)
    /// @param parent-id the old session ID
    /// @param child-id the new session ID
    on-session-rotate: func(parent-id: string, child-id: string);

    /// Called before context compression begins
    /// @param message-count number of messages before compression
    on-compression-start: func(message-count: u32);

    /// Called after context compression completes
    /// @param status result: "compacted", "unchanged", "ineffective"
    on-compression-complete: func(status: string);
}

/// Host exports to guest: plugin registry for tool and CLI command registration.
/// Plugins can register tools at init or at any point during their lifetime
/// (runtime registration). The host captures the exported handler functions.

/// Plugin registry interface — allows plugins to register and unregister tools.
interface plugin-registry {
    /// Record type for tool handler handles (identifies exported WASM functions)
    record tool-handle {
        id: string,
        handler: string,
    }

    /// Register a tool — host captures the guest's exported handler function.
    /// Called at init or anytime during plugin lifetime (runtime registration).
    register-tool: func(name: string, description: string, schema: string, capabilities: list<string>) -> tool-handle;

    /// Register a group of tools at once
    register-toolset: func(name: string, tools: list<tool-handle>);

    /// Unregister a previously registered tool
    unregister-tool: func(handle: tool-handle);
}

/// CLI command interface — allows plugins to register subcommands.
interface cli-command {
    /// Command handle record — records a CLI handler that the guest exports.
    record command-handle {
        name: string,
        handler: string,
    }

    /// Register a CLI subcommand — host captures the handler export.
    register-command: func(name: string, handler: command-handle, description: string, aliases: list<string>);
}

/// Host services interface — plugins call these to use host-provided capabilities.
/// The host gates access via capability declarations on the plugin.

interface host-services {
    /// Host logging — bounded (1000 entries, 4KB max). Plugins call this for structured logging.
    log: func(level: string, message: string);

    /// Read file safely — gated by host's `is-path-safe()` host function. Plugin must declare workspace-read capability.
    read-file: func(path: string) -> result<string, string>;

    /// HTTP request via host proxy — gated by host. Plugin must declare http capability. Timeout enforced by host.
    http-request: func(url: string, method: string, headers: list<string>, body: string) -> result<string, string>;

    /// Invoke a host tool by name and JSON args — depth-limited (host tracks invocation depth). Plugin must declare tool-invoke capability.
    tool-invoke: func(tool-name: string, args: string) -> result<string, string>;

    /// Check if a secret exists by name — returns bool, never exposes raw secret values.
    secret-exists: func(name: string) -> bool;

    /// Current wall-clock time in milliseconds.
    now-millis: func() -> u64;
}

/// Message injection — Phase 2: host provides this so plugins can inject messages.
/// TODO Phase 2: connect to agent queue
interface inject-message {
    /// Message record for injection into conversation context
    record message-record {
        content: string,
        role: string,
    }

    /// Inject a message into the current conversation context.
    inject: func(msg: message-record);
}

/// LLM access — Phase 2: host binds to active model config
/// TODO Phase 2: bind to active model config at runtime
interface chat-completion {
    /// Chat message record
    record chat-message {
        role: string,
        content: string,
    }

    /// Chat response record
    record chat-response {
        message: chat-message,
        usage: string,
    }

    /// Send a chat completion request through the host's active LLM config.
    /// The host manages model selection, API keys, and rate limiting.
    complete: func(messages: list<chat-message>) -> chat-response;
}
